  },
  "keyFeatures": [
    "Carousel and gallery modes with smooth animations",
    "Responsive breakpoints with customizable options",
    "Autoplay with hover pause and directional control",
    "Touch and mouse drag support with swipe detection",
    "Lazy loading for optimized image loading",
    "Custom events for lifecycle hooks",
    "Vertical and horizontal orientation support",
    "Loop and rewind navigation modes",
    "Accessibility with ARIA attributes and keyboard navigation",
    "Fixed width, auto width, and percentage-based layouts",
    "Edge padding and gutter spacing",
    "Center mode for active slide positioning",
    "Nested slider support",
    "IE8+ browser support with polyfills"
  ],
  "publicApiSurface": [
    "tns(options) - Initialize slider",
    "slider.getInfo() - Get slider information",
    "slider.goTo(target) - Navigate to slide",
    "slider.play() - Start autoplay",
    "slider.pause() - Stop autoplay",
    "slider.destroy() - Destroy slider",
    "slider.rebuild() - Rebuild slider",
    "slider.updateSliderHeight() - Update height",
    "slider.refresh() - Refresh slider",
    "slider.events.on(event, callback) - Subscribe to event",
    "slider.events.off(event, callback) - Unsubscribe from event",
    "Event: indexChanged - Fires when slide index changes",
    "Event: transitionStart - Fires when transition starts",
    "Event: transitionEnd - Fires when transition ends",
    "Event: touchStart/touchMove/touchEnd - Touch events",
    "Event: dragStart/dragMove/dragEnd - Drag events",
    "Event: newBreakpointStart/newBreakpointEnd - Breakpoint events"
  ]
}
