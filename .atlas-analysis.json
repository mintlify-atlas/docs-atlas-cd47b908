{
  "projectType": "sdk-library",
  "projectName": "Tiny Slider",
  "projectDescription": "Vanilla JavaScript slider for all purposes with carousel, gallery modes, responsive options, and touch support.",
  "theme": "palm",
  "primaryColor": "#848c8e",
  "lightColor": "#11161e",
  "darkColor": "#cfd0d2",
